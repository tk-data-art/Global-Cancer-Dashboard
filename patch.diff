diff --git a/apps/cancer-dashboard/index.html b/apps/cancer-dashboard/index.html
new file mode 100644
index 0000000000000000000000000000000000000000..06df0a74018251452d0e378dc90a5be13f3ffb66
--- /dev/null
+++ b/apps/cancer-dashboard/index.html
@@ -0,0 +1,143 @@
+<!DOCTYPE html>
+<html lang="en">
+  <head>
+    <meta charset="UTF-8" />
+    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
+    <title>Global Cancer Intelligence Dashboard</title>
+    <meta
+      name="description"
+      content="Interactive cancer dashboard using official WHO, IARC/GLOBOCAN, and national health sources."
+    />
+    <link rel="stylesheet" href="./styles.css" />
+    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" defer></script>
+    <script type="module" src="./app.js" defer></script>
+  </head>
+  <body>
+    <div class="app-shell">
+      <header class="hero card">
+        <div>
+          <p class="eyebrow">WHO + IARC / GLOBOCAN cancer analytics</p>
+          <h1>Global cancer intelligence dashboard</h1>
+          <p class="hero-copy">
+            Explore curated country snapshots built from the latest official releases in the bundled dataset, compare mortality patterns, and drill into region-level detail where national portals publish subnational records.
+          </p>
+        </div>
+        <div class="hero-note">
+          <h3>Data scope</h3>
+          <p id="data-scope-note"></p>
+          <ul>
+            <li>Global totals based on WHO and IARC summaries.</li>
+            <li>Country records reference official fact sheets and national portals.</li>
+            <li>Missing geographies stay visible on the map and degrade gracefully.</li>
+          </ul>
+        </div>
+      </header>
+
+      <section class="kpi-grid" id="kpi-grid"></section>
+
+      <section class="controls-card card">
+        <label class="search-box">
+          <span>Search country</span>
+          <input id="search-input" placeholder="Type a country name" />
+        </label>
+        <label>
+          <span>Cancer type</span>
+          <select id="cancer-type-filter"></select>
+        </label>
+        <label>
+          <span>Year</span>
+          <select id="year-filter"></select>
+        </label>
+        <label>
+          <span>Gender</span>
+          <select id="gender-filter">
+            <option>All</option>
+            <option>Female</option>
+            <option>Male</option>
+          </select>
+        </label>
+      </section>
+
+      <section class="layout-grid">
+        <div class="card map-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">Global cancer map</p>
+              <h2>Choropleth by mortality rate</h2>
+            </div>
+            <div class="legend">
+              <span><i class="low"></i>Low</span>
+              <span><i class="medium"></i>Medium</span>
+              <span><i class="high"></i>High</span>
+            </div>
+          </div>
+          <div id="world-map" class="plot"></div>
+          <p class="muted small">
+            Hover a country for a quick summary, then click to update detailed KPIs, trend lines, cancer-type mix, and region-level views where official subnational data is bundled.
+          </p>
+        </div>
+        <aside class="card ranking-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">Top 10 countries</p>
+              <h2>Most affected in bundled data</h2>
+            </div>
+          </div>
+          <ol id="top-ten-list"></ol>
+        </aside>
+      </section>
+
+      <section class="details-grid">
+        <div class="card details-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">Country dashboard</p>
+              <h2 id="country-name"></h2>
+            </div>
+            <span id="risk-pill" class="pill"></span>
+          </div>
+          <div class="stats-grid" id="country-stats"></div>
+          <div class="comparison-strip" id="comparison-strip"></div>
+          <div class="source-list" id="country-sources"></div>
+        </div>
+
+        <div class="card chart-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">Trend view</p>
+              <h2>Cases vs deaths</h2>
+            </div>
+          </div>
+          <div id="trend-chart" class="plot"></div>
+        </div>
+
+        <div class="card chart-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">Cancer type insights</p>
+              <h2>Share of top cancers</h2>
+            </div>
+          </div>
+          <div id="cancer-type-chart" class="plot"></div>
+        </div>
+
+        <div class="card chart-card">
+          <div class="section-heading">
+            <div>
+              <p class="eyebrow">State / region analysis</p>
+              <h2 id="region-title"></h2>
+            </div>
+          </div>
+          <div id="region-chart" class="plot"></div>
+          <p id="region-empty" class="muted hidden">Add subnational records to the dataset to unlock drill-down analytics for this country.</p>
+        </div>
+      </section>
+
+      <footer class="footer-note">
+        <p>
+          Sources include WHO cancer fact sheets, IARC / Global Cancer Observatory country fact sheets, and official national portals referenced inside each country card. Regional breakdowns are shown only where bundled official subnational records are available.
+        </p>
+      </footer>
+    </div>
+  </body>
+</html>
diff --git a/apps/cancer-dashboard/styles.css b/apps/cancer-dashboard/styles.css
new file mode 100644
index 0000000000000000000000000000000000000000..d6555a947a794b4c1bde9bfb0ccbdc0a9526c523
--- /dev/null
+++ b/apps/cancer-dashboard/styles.css
@@ -0,0 +1,56 @@
+:root {
+  color-scheme: dark;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
+  background: #020617;
+  color: #e2e8f0;
+}
+* { box-sizing: border-box; }
+body { margin: 0; background: radial-gradient(circle at top, #0f172a 0, #020617 55%); }
+a { color: #7dd3fc; }
+button, input, select { font: inherit; }
+input, select { width: 100%; background: rgba(15, 23, 42, 0.88); border: 1px solid rgba(148, 163, 184, 0.2); color: #e2e8f0; padding: 12px 14px; border-radius: 14px; }
+.app-shell { width: min(1400px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 48px; }
+.card { background: rgba(15, 23, 42, 0.88); border: 1px solid rgba(148, 163, 184, 0.15); border-radius: 24px; box-shadow: 0 20px 50px rgba(15, 23, 42, 0.35); backdrop-filter: blur(14px); }
+.hero { display: grid; grid-template-columns: 2.5fr 1fr; gap: 24px; padding: 32px; }
+.hero h1 { font-size: clamp(2rem, 4vw, 4rem); margin: 0 0 12px; }
+.hero-copy, .muted { color: #94a3b8; }
+.eyebrow { text-transform: uppercase; letter-spacing: 0.16em; color: #fda4af; font-size: 0.72rem; margin-bottom: 8px; }
+.hero-note { background: rgba(15, 118, 110, 0.12); border-radius: 20px; padding: 20px; }
+.hero-note ul { padding-left: 18px; color: #cbd5e1; }
+.kpi-grid, .layout-grid, .details-grid { display: grid; gap: 20px; margin-top: 20px; }
+.kpi-grid { grid-template-columns: repeat(4, 1fr); }
+.layout-grid { grid-template-columns: 2fr 1fr; align-items: start; }
+.details-grid { grid-template-columns: repeat(2, 1fr); }
+.kpi-card, .controls-card, .map-card, .ranking-card, .details-card, .chart-card { padding: 24px; }
+.kpi-card h3 { margin: 8px 0; font-size: 1.7rem; }
+.controls-card { display: grid; grid-template-columns: 2fr repeat(3, 1fr); gap: 16px; align-items: end; margin-top: 20px; }
+.controls-card label span { display: block; margin-bottom: 8px; color: #cbd5e1; }
+.search-box input { margin-top: 8px; }
+.section-heading { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; margin-bottom: 18px; }
+.section-heading h2 { margin: 0; font-size: 1.35rem; }
+.legend { display: flex; gap: 12px; flex-wrap: wrap; color: #cbd5e1; }
+.legend span { display: inline-flex; gap: 8px; align-items: center; }
+.legend i { width: 12px; height: 12px; border-radius: 999px; display: inline-block; }
+.legend .low { background: #0f766e; }
+.legend .medium { background: #ca8a04; }
+.legend .high { background: #be123c; }
+.plot { min-height: 340px; }
+.small { font-size: 0.88rem; }
+.ranking-card ol { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
+.ranking-card li button { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; border-radius: 14px; border: 1px solid rgba(148, 163, 184, 0.15); background: rgba(15, 23, 42, 0.7); color: inherit; cursor: pointer; }
+.ranking-card li.active button { border-color: rgba(244, 63, 94, 0.65); background: rgba(136, 19, 55, 0.35); }
+.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin: 18px 0; }
+.stats-grid div, .comparison-strip div { background: rgba(15, 23, 42, 0.7); border-radius: 18px; padding: 16px; border: 1px solid rgba(148, 163, 184, 0.12); }
+.stats-grid span, .comparison-strip span, .source-list span { display: block; color: #94a3b8; margin-bottom: 8px; }
+.stats-grid strong, .comparison-strip strong { font-size: 1.2rem; }
+.comparison-strip { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
+.source-list { margin-top: 18px; display: grid; gap: 8px; }
+.pill { border-radius: 999px; padding: 8px 12px; font-size: 0.82rem; font-weight: 700; }
+.pill.high { background: rgba(190, 24, 93, 0.18); color: #fda4af; }
+.pill.medium { background: rgba(202, 138, 4, 0.16); color: #fde68a; }
+.pill.low { background: rgba(13, 148, 136, 0.16); color: #99f6e4; }
+.footer-note { color: #94a3b8; margin-top: 24px; padding-bottom: 24px; }
+.hidden { display: none; }
+@media (max-width: 1100px) {
+  .hero, .layout-grid, .details-grid, .kpi-grid, .controls-card, .stats-grid, .comparison-strip { grid-template-columns: 1fr; }
+}
